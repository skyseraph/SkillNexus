{
  "name": "skill-nexus",
  "version": "0.1.0",
  "description": "Skill 创造平台：让Skill可生成、可量化、可管理、可成长",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/rebuild-sqlite.js && electron-vite dev",
    "build": "node scripts/rebuild-sqlite.js && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "node scripts/rebuild-sqlite.js",
    "rebuild": "node scripts/rebuild-sqlite.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke",
    "test:e2e:security": "playwright test e2e/security",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:all": "electron-vite build && electron-builder --mac --win"
  },
  "build": {
    "appId": "com.skillnexus.app",
    "productName": "SkillNexus",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map",
      "resources/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.0.0",
    "electron-store": "^8.2.0",
    "fflate": "^0.8.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^10.2.1",
    "playwright": "^1.59.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
